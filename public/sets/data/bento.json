  "recipes": [
    {
      "title": "ミートボールの甘酢あん",
      "servings": 2,
      "cookMinutes": 20,
      "effortLevel": "normal",
      "tags": [
        "和食",
        "お弁当",
        "作り置き"
      ],
      "season": "all",
      "suitableFor": [
        "lunch",
        "dinner"
      ],
      "ingredients": [
        {
          "name": "豚ひき肉",
          "amount": "250",
          "unit": "g"
        },
        {
          "name": "玉ねぎ",
          "amount": "1/4",
          "unit": "個"
        },
        {
          "name": "しょうが(すりおろし)",
          "amount": "1",
          "unit": "小さじ",
          "memo": "チューブのものでもよい"
        },
        {
          "name": "塩",
          "amount": "少々",
          "unit": "",
          "memo": "1食あたり約0.25gが目安"
        },
        {
          "name": "片栗粉(肉だね用)",
          "amount": "1",
          "unit": "大さじ"
        },
        {
          "name": "サラダ油",
          "amount": "適量",
          "unit": "",
          "memo": "揚げ焼き用。大さじ2〜3が目安"
        },
        {
          "name": "酢",
          "amount": "2",
          "unit": "大さじ",
          "seasoningGroup": 1
        },
        {
          "name": "砂糖",
          "amount": "2",
          "unit": "大さじ",
          "seasoningGroup": 1
        },
        {
          "name": "しょうゆ",
          "amount": "1",
          "unit": "大さじ",
          "seasoningGroup": 1
        },
        {
          "name": "ケチャップ",
          "amount": "1",
          "unit": "大さじ",
          "seasoningGroup": 1
        },
        {
          "name": "片栗粉(あん用)",
          "amount": "2",
          "unit": "小さじ",
          "seasoningGroup": 1
        },
        {
          "name": "水",
          "amount": "100",
          "unit": "ml",
          "seasoningGroup": 1
        },
        {
          "name": "いりごま",
          "amount": "適量(お好みで)",
          "unit": ""
        }
      ],
      "steps": [
        {
          "text": "玉ねぎはみじん切りにする。",
          "memo": "粗いと丸めたときに崩れやすいので、できるだけ細かく刻むこと。"
        },
        {
          "text": "ボウルに豚ひき肉・玉ねぎ・しょうが(すりおろし)・塩・片栗粉(肉だね用)を入れ、粘りが出るまでよく混ぜて肉だねを作る。",
          "memo": "粘りが出るまで混ぜると、焼いたときに崩れにくくなる。"
        },
        {
          "text": "別の器に酢・砂糖・しょうゆ・ケチャップ・片栗粉(あん用)・水を混ぜ合わせ、甘酢あんのもとを作っておく。",
          "memo": "片栗粉は底に沈みやすいので、フライパンに入れる直前にもう一度混ぜて使うこと。"
        },
        {
          "text": "肉だねを一口大（直径3cmほど）に丸める。",
          "memo": "手のひらに薄くサラダ油をつけると、たねがつかず丸めやすい。"
        },
        {
          "text": "フライパンにサラダ油を中火で熱し、ミートボールを転がしながら揚げ焼きにして全体に焼き色をつける。",
          "minutes": 4,
          "memo": "・たねを入れるときは油がはねやすいので、そっと入れること。\n・一度に焼けるのはフライパンに重ならず並ぶ量まで。\n▽たくさん作るとき：・一度に焼けない場合は半量ずつに分ける。｜・手順5〜7（焼く→ふたで火を通す→あんをからめる）をひと組として繰り返す。｜・あんのもとも半量ずつ使う。"
        },
        {
          "text": "ふたをして弱火にし、中まで火を通す。",
          "minutes": 3,
          "memo": "いちばん大きい1個を切って中心の色を確認すると確実。赤みや生っぽい部分がなければ火が通った目安。赤ければふたをして1分ずつ追加加熱すること。"
        },
        {
          "text": "余分な油をキッチンペーパーで拭き取り、甘酢あんのもとをもう一度混ぜてから回し入れ、混ぜながらとろみがつくまで煮からめる。",
          "minutes": 2,
          "memo": "あんが透き通ってツヤが出たら完成の目安。"
        },
        {
          "text": "器に盛り、お好みでいりごまをふる。"
        }
      ],
      "memo": "・甘酢あんの「あん」とは、片栗粉でとろみをつけたたれのこと。\n・生のひき肉をこねた手・ボウルは、ほかの食材にさわる前に洗うこと。\n・お弁当に入れる場合は完全に冷まし、汁気を軽く切ってから詰めること。\n・粗熱を取ってから重ならないように並べて早めに冷蔵し、冷蔵で2〜3日を目安に食べ切ること。\n・小分けにして冷凍も可(約2〜3週間が目安)。食べるときは電子レンジで温めるとあんがやわらかく戻る。",
      "isFavorite": false,
      "cookedLogs": [],
      "searchWords": [],
      "createdAt": 0,
      "updatedAt": 0
    },
    {
      "title": "卯の花(おからの炒り煮)",
      "servings": 2,
      "cookMinutes": 20,
      "effortLevel": "easy",
      "tags": [
        "和食",
        "作り置き",
        "お弁当"
      ],
      "season": "all",
      "suitableFor": [
        "lunch",
        "dinner"
      ],
      "ingredients": [
        {
          "name": "生おから",
          "amount": "150",
          "unit": "g",
          "memo": "スーパーの豆腐売り場にあることが多い。「おからパウダー」は別物なので、生おからを使うこと"
        },
        {
          "name": "人参",
          "amount": "1/4",
          "unit": "本"
        },
        {
          "name": "油揚げ",
          "amount": "1",
          "unit": "枚",
          "memo": "1枚=20g程度が目安"
        },
        {
          "name": "小ねぎ",
          "amount": "2",
          "unit": "本"
        },
        {
          "name": "サラダ油",
          "amount": "適量",
          "unit": "",
          "memo": "大さじ1/2〜1が目安"
        },
        {
          "name": "だし汁",
          "amount": "200",
          "unit": "ml",
          "memo": "和風だしの素なら水100mlにつき小さじ1/2が目安",
          "seasoningGroup": 1
        },
        {
          "name": "しょうゆ",
          "amount": "1",
          "unit": "大さじ",
          "seasoningGroup": 1
        },
        {
          "name": "みりん",
          "amount": "1",
          "unit": "大さじ",
          "seasoningGroup": 1
        },
        {
          "name": "砂糖",
          "amount": "1/2",
          "unit": "大さじ",
          "seasoningGroup": 1
        }
      ],
      "steps": [
        {
          "text": "人参はせん切りにする。油揚げは熱湯をかけて油抜きをし、短冊切りにする。",
          "memo": "油抜きは、ざるにのせて両面に熱湯を回しかけるとよい。"
        },
        {
          "text": "小ねぎは小口切りにする。"
        },
        {
          "text": "フライパンにサラダ油を中火で熱し、人参と油揚げを炒める。",
          "minutes": 2,
          "memo": "量が多いときは深めのフライパンか鍋を使うと混ぜやすい。"
        },
        {
          "text": "生おからを加え、ほぐしながら全体に油がなじむまで炒める。",
          "minutes": 2,
          "memo": "おからは焦げやすいので、混ぜながら炒めること。"
        },
        {
          "text": "だし汁・しょうゆ・みりん・砂糖を加え、混ぜながら汁気が少なくなるまで炒り煮にする。",
          "minutes": 5,
          "memo": "木べらなどで混ぜたとき、鍋底に汁気がたまらない、しっとりした状態が火の止めどき。冷めると水分を吸って少し固くしまる。"
        },
        {
          "text": "火を止めて小ねぎを加えて混ぜ、粗熱を取る。"
        }
      ],
      "memo": "・卯の花（うのはな）とは、おからの別名。豆腐を作るときに豆乳を絞ったあとに残るのがおからで、白いぽろぽろとした見た目を初夏に咲く白い花「卯の花」にたとえた呼び名。おからの炒り煮の料理名としても使われる。\n・おからは食物繊維が豊富な食材。\n・お弁当に入れる場合は完全に冷ましてから詰めること。\n・おからは水分が多く傷みやすいので、粗熱が取れたら早めに冷蔵し、冷蔵で2〜3日を目安に食べ切ること。\n・小分けにして冷凍も可(約2〜3週間が目安)。",
      "isFavorite": false,
      "cookedLogs": [],
      "searchWords": [],
      "createdAt": 0,
      "updatedAt": 0
    },

        "dinner"
      ],
      "ingredients": [
        {
          "name": "白菜",
          "amount": "1/4",
          "unit": "株",
          "memo": "1/4株=約400gが目安"
        },
        {
          "name": "豚ロース薄切り肉(しゃぶしゃぶ用)",
          "amount": "200",
          "unit": "g"
        },
        {
          "name": "酒",
          "amount": "1",
          "unit": "大さじ"
        },
        {
          "name": "ポン酢",
          "amount": "3",
